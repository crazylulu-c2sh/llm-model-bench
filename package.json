{
  "name": "llm-model-bench",
  "version": "1.0.0",
  "private": true,
  "description": "Local LLM benchmarking (LM Studio, Ollama, OpenAI-compatible)",
  "scripts": {
    "postinstall": "pnpm --filter @llm-bench/shared run build",
    "dev": "node scripts/dev.mjs",
    "dev:kill": "node scripts/dev-kill.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "playwright test",
    "prepare:vision": "node scripts/prepare-vision-assets.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24 <25"
  },
  "volta": {
    "node": "24.12.0",
    "pnpm": "11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "sharp": "^0.34.5"
  }
}
