# llm-model-bench 환경 변수 예시 — 필요한 것만 복사해 사용하세요. 기본값은 무설정이어도 로컬 동작.

# ── 벤치 서버 (@llm-bench/server) ─────────────────────────────────────────────
PORT=20080
# BENCH_DB_PATH=./data/bench.sqlite
# WEB_DIST_PATH=../web/dist

# LM Studio lms CLI (loopback + 아래 플래그 3중 게이트)
# ENABLE_LMS_CLI=1

# 원격 클라이언트가 네이티브 LM Studio 모델 관리(/monitor/lms/native/*)를 쓰게 허용.
# 0으로 열려면 BENCH_API_KEYS 설정 필수(없으면 401). 기본(미설정/1)은 loopback 전용.
# STRICT_LOCALHOST=0

# 비전 LLM-as-Judge (meme/wireframe 채점) — #83 커스텀 시나리오 judge 루브릭도 이 경로 사용
# LLM_JUDGE_ENABLED=1
# ANTHROPIC_API_KEY=sk-ant-...

# #83: 부팅 시 이 디렉토리의 *.json 커스텀 시나리오를 레지스트리에 로드(ops 프로비저닝용).
# CUSTOM_SCENARIOS_DIR=./custom-scenarios

# API 인증(opt-in) — 설정 시 /api/* 에 Bearer/x-api-key 필요. provider apiKey와 별개.
# BENCH_API_KEYS=key-one,key-two
# BENCH_TRUST_LOOPBACK=1
# 리버스 프록시(도커/nginx) 뒤에서 웹 UI 401을 막으려면:
# BENCH_TRUST_PROXY=1
# BENCH_CORS_ORIGINS=https://your-ui.example

# ── MCP 서버 (@llm-bench/mcp) ────────────────────────────────────────────────
BENCH_API_URL=http://127.0.0.1:20080
BENCH_API_VERSION=/api/v1
# 벤치 서버 키(위 BENCH_API_KEYS 중 하나) — MCP가 Authorization: Bearer 로 전송
# BENCH_API_KEY=key-one
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_PORT=20090
# http 엔드포인트(agent→MCP) 보호. 비루프백 노출 시 필수.
# MCP_HTTP_TOKEN=change-me
# DNS-rebinding 방어(Host/Origin 허용 목록)
# MCP_ALLOWED_HOSTS=127.0.0.1,localhost
# MCP_ALLOWED_ORIGINS=https://your-agent.example
# BENCH_HTTP_TIMEOUT_MS=900000

# docker compose 로 mcp 포트를 원격 노출할 때만:
# BENCH_API_KEYS=... BENCH_API_KEY=... MCP_HTTP_TOKEN=...
