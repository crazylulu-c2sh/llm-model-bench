{
  "name": "@llm-bench/mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "llm-bench-mcp": "./dist/index.js",
    "llm-bench-compare": "./dist/compare-cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/compare-cli.ts --format esm --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@llm-bench/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
